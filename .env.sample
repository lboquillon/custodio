# Custodio configuration. Copy to .env and adjust. All values are optional;
# defaults are shown.

# --- engine & networking ---
CUSTODIO_ENGINE=presidio                 # presidio (full NER, recommended) or regex (no spaCy, lower recall)
CUSTODIO_UPSTREAM=https://api.anthropic.com
CUSTODIO_HOST=127.0.0.1
CUSTODIO_PORT=3000

# --- detection ---
CUSTODIO_LANGUAGE=en
CUSTODIO_SPACY_MODEL=en_core_web_lg      # or en_core_web_sm for a smaller model
CUSTODIO_SCORE_THRESHOLD=0.5             # anonymize spans at/above this score
CUSTODIO_SHADOW_THRESHOLD=0.3            # flag [shadow, score) as "possible miss"
# CUSTODIO_ALLOWED_ENTITIES=EMAIL_ADDRESS,PHONE_NUMBER,CREDIT_CARD,US_SSN,IP_ADDRESS,PERSON
# CUSTODIO_DENIED_ENTITIES=DATE_TIME,URL

# --- payload scope ---
CUSTODIO_ANONYMIZE_SYSTEM=true
CUSTODIO_ANONYMIZE_TOOL_INPUTS=true      # tool_use inputs + tool_result content
CUSTODIO_ANONYMIZE_TOOL_DEFS=false       # tool schemas — leaving on can break tools
CUSTODIO_ANONYMIZE_METADATA=true         # metadata.user_id (often an email/username)

# --- audit ---
CUSTODIO_AUDIT_CAPACITY=500
CUSTODIO_STORE_FULL_PII=false            # true retains clear-text values (debug only)
# CUSTODIO_AUDIT_JSONL=./custodio-audit.jsonl
# Redis-backed audit store + live dashboard pub/sub. Unset = in-memory (per-process).
# docker compose sets this automatically; for a local Redis use e.g.:
# CUSTODIO_REDIS_URL=redis://localhost:6379/0
# CUSTODIO_REDIS_PREFIX=custodio
# CUSTODIO_REDIS_TTL_SECONDS=0           # per-event expiry; 0 = keep until evicted

# --- safety ---
CUSTODIO_FAIL_OPEN=false                 # engine load failure / unparseable body: false=block, true=forward raw
CUSTODIO_MAX_BODY_BYTES=26214400         # reject bodies larger than this (0 = no limit)
CUSTODIO_TIMEOUT_SECONDS=600
# Protect the /custodio/* audit surface (dashboard, events, stream). When set,
# open the dashboard as /custodio/dashboard?token=YOUR_TOKEN. Unset = open (local).
# CUSTODIO_AUDIT_TOKEN=change-me-to-a-long-random-string
